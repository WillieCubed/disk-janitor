# disk-janitor config — copy to ~/.disk-janitor/config.env (install does this for you),
# edit, then re-run `disk-janitor install` to apply schedule/threshold changes.

# Shared Cargo target dir — all projects/worktrees compile dependencies here once.
TARGET_DIR="$HOME/.cache/cargo-target"

# Roots scanned for worktrees / build artifacts. Must NOT be $HOME or /.
PROJECT_DIRS=("$HOME/Projects")

# Repos to `git worktree prune`. Empty = auto-discover git repos under PROJECT_DIRS.
# GIT_REPOS=("$HOME/Projects/my-monorepo")

# Filesystem whose free space `status` reports.
# macOS default: /System/Volumes/Data   Linux default: $HOME
# DATA_PATH="/System/Volumes/Data"

# pnpm package-import-method: clone (APFS reflink), hardlink (Linux), copy, or auto.
NPM_IMPORT_METHOD="clone"

# Age thresholds (days).
SWEEP_DAYS=10        # cargo build artifacts older than this are swept
NM_DAYS=30           # node_modules untouched this long are removed
WORKTREE_DAYS=14     # idle agent worktree checkouts (.claude/worktrees/agent-*) removed

# Weekly schedule (0 = Sunday).
RUN_WEEKDAY=0
RUN_HOUR=3
RUN_MINUTE=0

# 1 = manage a worktree-guidance block in agent config files (~/.codex/AGENTS.md, ~/.claude/CLAUDE.md).
AGENT_GUIDANCE=0
